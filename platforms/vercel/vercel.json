{
  "version": 2,
  "buildCommand": "cd ../.. && npm ci && cd platforms/vercel && npm ci && npm run build",
  "outputDirectory": "platforms/vercel/dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs22.x",
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "../../server/**,../../shared/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": []
}
