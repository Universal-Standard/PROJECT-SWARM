{
  "name": "project-swarm-cloudflare",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "PROJECT-SWARM — Cloudflare-native deployment (Pages + Workers + D1 + Durable Objects + Queues)",
  "scripts": {
    "dev": "wrangler pages dev dist/ --compatibility-date=2024-11-24 --d1=DB:swarm-local.db",
    "dev:worker": "wrangler dev worker/src/index.ts",
    "build": "npm run build:frontend && npm run build:worker",
    "build:frontend": "vite build",
    "build:worker": "wrangler deploy --dry-run --outdir worker/dist worker/src/index.ts",
    "deploy": "npm run build && npm run deploy:worker && npm run deploy:pages",
    "deploy:worker": "wrangler deploy worker/src/index.ts",
    "deploy:pages": "wrangler pages deploy dist/",
    "db:migrate:local": "wrangler d1 execute project-swarm-d1 --local --file=migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 migrations apply project-swarm-d1",
    "type-check": "tsc --noEmit && tsc --noEmit -p worker/tsconfig.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@hono/zod-validator": "^0.4.3",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tanstack/react-query": "^5.99.0",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^11.13.1",
    "hono": "^4.7.9",
    "lucide-react": "^0.453.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "recharts": "^2.15.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "wouter": "^3.9.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250429.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.1.18",
    "typescript": "5.9.3",
    "vite": "^6.4.2",
    "wrangler": "^3.114.9"
  }
}
